# === LLM Provider Keys ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
GROQ_API_KEY=gsk_...

# === Search Tool Key (Tavily — the only search provider) ===
TAVILY_API_KEY=tvly-...

# === Redis / Celery ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# === App Settings ===
MAX_DEBATE_ITERATIONS=3
LOG_LEVEL=INFO

# === Per-role Model Overrides (optional — defaults live in app/config.py) ===
# Uncomment to override. Provider is chosen by ID prefix: gemini* / claude* / gpt*|o* / else->Groq.
# RESEARCHER_MODEL=gemini-2.5-pro
# ANALYST_A_MODEL=gemini-2.5-pro
# ANALYST_B_MODEL=claude-sonnet-4-6
# JUDGE_MODEL=gpt-4.1
# COMPILER_MODEL=gemini-2.5-pro

# === Pilot auth + public-data mode (VC-readiness layer, 2026-07-06) ===
# API_KEYS="alice:key1,bob:key2"   # empty/unset = auth disabled (local single-operator)
# UPLOADS_ENABLED=true             # false = public-data mode (no confidential uploads)
